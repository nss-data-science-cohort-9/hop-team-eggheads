CREATE MATERIALIZED VIEW hop_limited_to_npi AS
	SELECT
		*
	FROM
		nppes_taxonomy_filter AS PT
		INNER JOIN NUCC AS N ON PT.PRIMARY_TAXONOMY_CODE = N.CODE
		INNER JOIN hop_limited AS H ON H.TO_NPI = PT.NPI
	WHERE
	PT.entity_type_code = 2 AND N.grouping Ilike '%hospital%'
		;

-- - Only referrals in the Nashville CBSA. 
-- CODE: pulls out nashville cbsa but need to add this to the nppes_taxonomy_filter VIEW

CREATE MATERIALIZED VIEW nash_from_npi AS
WITH cbsa_nash_zip AS 
(SELECT DISTINCT(zip)
FROM zip_cbsa
WHERE usps_zip_pref_state = 'TN' AND cbsa = '34980')
SELECT n.*,
--lf.primary_taxonomy_code,
code,
lf.grouping,
classification,
specialization,
definition,
notes,
display_name,
lf.section,
from_npi,
to_npi,
patient_count,
transaction_count,
average_day_wait,
std_day_wait
FROM nppes_taxonomy_filter AS n
INNER JOIN cbsa_nash_zip AS c 
ON c.zip = LEFT(n.address_postal_code,5)::NUMERIC
INNER JOIN hop_limited_from_npi AS lf
USING(npi);


CREATE MATERIALIZED VIEW nash_to_npi AS
WITH cbsa_nash_zip AS 
(SELECT DISTINCT(zip)
FROM zip_cbsa
WHERE usps_zip_pref_state = 'TN' AND cbsa = '34980')
SELECT n.*,
--lf.primary_taxonomy_code,
code,
lf.grouping,
classification,
specialization,
definition,
notes,
display_name,
lf.section,
from_npi,
to_npi,
patient_count,
transaction_count,
average_day_wait,
std_day_wait
FROM nppes_taxonomy_filter AS n
INNER JOIN cbsa_nash_zip AS c 
ON c.zip = LEFT(n.address_postal_code,5)::NUMERIC
INNER JOIN hop_limited_to_npi AS lf
USING(npi);



